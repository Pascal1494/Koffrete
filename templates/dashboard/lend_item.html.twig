{% extends 'base.html.twig' %}

{% block title %}Prêter un Exemplaire - Koffrete{% endblock %}

{% block body %}
<nav class="bg-indigo-600 shadow-md">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
            <div class="flex items-center">
                <a href="{{ path('app_dashboard') }}" class="text-white text-xl font-bold hover:opacity-90 transition">Koffrete 🗃️</a>
                <span class="text-indigo-200 text-sm ml-4 font-medium hidden sm:block">Prêt de Copie</span>
            </div>
            <div class="flex items-center space-x-4">
                <a href="{{ path('app_dashboard') }}" class="text-indigo-100 hover:text-white text-sm font-medium">
                    ← Retour au tableau de bord
                </a>
            </div>
        </div>
    </div>
</nav>

<div class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="bg-white py-8 px-6 shadow sm:rounded-lg sm:px-10 border border-gray-100">
        <h2 class="text-2xl font-bold text-gray-900 mb-2 pb-4 border-b border-gray-100 flex items-center">
            🤝 Prêter cet Exemplaire
        </h2>
        <p class="text-sm text-gray-500 mb-6">
            Vous prêtez : <span class="font-bold text-gray-800">"{{ item.media.title }}"</span> ({% if item.media.author is defined %}Livre{% else %}DVD{% endif %})
        </p>

        <form method="post" class="space-y-6">
            <div>
                <label for="borrower" class="block text-sm font-medium text-gray-700">
                    Nom de l'emprunteur
                </label>
                <div class="mt-1">
                    <input type="text" name="borrower" id="borrower" required placeholder="ex: Jean Dupont" class="appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm">
                </div>
                <p class="text-xs text-gray-400 mt-2">Le prêt est enregistré par défaut pour une durée recommandée de 14 jours.</p>
            </div>

            <div class="flex items-center justify-end space-x-3 pt-6 border-t border-gray-100">
                <a href="{{ path('app_dashboard') }}" class="px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none">
                    Annuler
                </a>
                <button type="submit" class="px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                    Confirmer le Prêt
                </button>
            </div>
        </form>
    </div>
</div>
{% endblock %}
