{% extends 'base.html.twig' %}

{% block title %}{{ title }} - Koffrete{% endblock %}

{% block body %}
<nav class="bg-indigo-600 shadow-md">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
            <div class="flex items-center">
                <span class="text-white text-xl font-bold">Koffrete 🗃️</span>
                <span class="text-indigo-200 text-sm ml-4 font-medium hidden sm:block">Ajout de Média</span>
            </div>
            <div class="flex items-center space-x-4">
                <a href="{{ path('app_dashboard') }}" class="text-indigo-100 hover:text-white text-sm font-medium">
                    ← Retour au tableau de bord
                </a>
            </div>
        </div>
    </div>
</nav>

<div class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="bg-white py-8 px-6 shadow sm:rounded-lg sm:px-10 border border-gray-100">
        <h2 class="text-2xl font-bold text-gray-900 mb-6 border-b border-gray-100 pb-4 flex items-center">
            {% if type == 'book' %}📖{% else %}🎬{% endif %}
            <span class="ml-2">{{ title }}</span>
        </h2>

        {{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}
            {% if not form.vars.valid %}
                <div class="bg-red-50 border-l-4 border-red-400 p-4 rounded-md mb-6">
                    <div class="flex">
                        <div class="flex-shrink-0">
                            ❌
                        </div>
                        <div class="ml-3">
                            <p class="text-sm text-red-700">
                                Un problème est survenu lors de l'enregistrement de l'exemplaire.
                            </p>
                            <!-- Global errors (such as AssertQuota!) -->
                            {% for error in form.vars.errors %}
                                <p class="text-xs text-red-600 mt-1 font-semibold">{{ error.message }}</p>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            {% endif %}

            <!-- Form fields for Media (Embedded) -->
            <div class="space-y-4">
                <h3 class="text-sm font-semibold uppercase tracking-wider text-indigo-600 mb-2 border-b border-indigo-50 pb-1">
                    1. Caractéristiques de l'Édition (Catalogue)
                </h3>
                {{ form_widget(form.media) }}
            </div>

            <!-- Form fields for Copy (Condition, Notes) -->
            <div class="space-y-4 mt-6">
                <h3 class="text-sm font-semibold uppercase tracking-wider text-indigo-600 mb-2 border-b border-indigo-50 pb-1">
                    2. Détails de Votre Exemplaire
                </h3>
                
                <div>
                    {{ form_label(form.condition) }}
                    <div class="mt-1">
                        {{ form_widget(form.condition) }}
                    </div>
                    <p class="text-xs text-red-600 mt-1 font-semibold">{{ form_errors(form.condition) }}</p>
                </div>

                <div>
                    {{ form_label(form.personalNotes) }}
                    <div class="mt-1">
                        {{ form_widget(form.personalNotes) }}
                    </div>
                    <p class="text-xs text-red-600 mt-1">{{ form_errors(form.personalNotes) }}</p>
                </div>
            </div>

            <div class="flex items-center justify-end space-x-3 pt-6 border-t border-gray-100">
                <a href="{{ path('app_dashboard') }}" class="px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                    Annuler
                </a>
                <button type="submit" class="px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                    Ajouter à ma bibliothèque
                </button>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
