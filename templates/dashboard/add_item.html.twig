{% extends 'base.html.twig' %}

{% block title %}{{ title }} - Koffrete{% endblock %}

{% block body %}
<nav class="bg-indigo-600 shadow-md">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
            <div class="flex items-center">
                <span class="text-white text-xl font-bold">Koffrete 🗃️</span>
                <span class="text-indigo-200 text-sm ml-4 font-medium hidden sm:block">Ajout de Média</span>
            </div>
            <div class="flex items-center space-x-4">
                <a href="{{ path('app_dashboard') }}" class="text-indigo-100 hover:text-white text-sm font-medium">
                    ← Retour au tableau de bord
                </a>
            </div>
        </div>
    </div>
</nav>

<div class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="bg-white py-8 px-6 shadow sm:rounded-lg sm:px-10 border border-gray-100">
        <h2 class="text-2xl font-bold text-gray-900 mb-6 border-b border-gray-100 pb-4 flex items-center">
            {% if type == 'book' %}📖{% else %}🎬{% endif %}
            <span class="ml-2">{{ title }}</span>
        </h2>

        <!-- Quick API Autofill Widget -->
        <div class="bg-indigo-50 border border-indigo-100 rounded-lg p-4 mb-6">
            <h4 class="text-xs font-bold uppercase tracking-wider text-indigo-800 mb-2">🔍 Assistant de Remplissage Automatique</h4>
            {% if type == 'book' %}
                <div class="flex space-x-2">
                    <input type="text" id="api_search_isbn" placeholder="Saisissez un ISBN (ex: 9780261103344)" class="appearance-none block w-full px-3 py-1.5 border border-gray-300 rounded-md shadow-sm text-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500">
                    <button type="button" id="btn_search_book" class="inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-semibold rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700">
                        Rechercher
                    </button>
                </div>
            {% else %}
                <div class="relative flex flex-col space-y-2">
                    <div class="flex space-x-2">
                        <input type="text" id="api_search_title" placeholder="Rechercher un titre de film (ex: Inception)" class="appearance-none block w-full px-3 py-1.5 border border-gray-300 rounded-md shadow-sm text-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500">
                        <button type="button" id="btn_search_movie" class="inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-semibold rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700">
                            Rechercher
                        </button>
                    </div>
                    <!-- Suggestion list -->
                    <div id="movie_suggestions" class="absolute left-0 right-0 top-10 bg-white border border-gray-200 rounded-md shadow-lg max-h-60 overflow-y-auto hidden z-50"></div>
                </div>
            {% endif %}
            <p id="api_status" class="text-xs text-gray-500 mt-2 italic hidden"></p>
        </div>

        {{ form_start(form, {'attr': {'id': 'media_form', 'class': 'space-y-6'}}) }}
            {% if not form.vars.valid %}
                <div class="bg-red-50 border-l-4 border-red-400 p-4 rounded-md mb-6">
                    <div class="flex">
                        <div class="flex-shrink-0">
                            ❌
                        </div>
                        <div class="ml-3">
                            <p class="text-sm text-red-700">
                                Un problème est survenu lors de l'enregistrement de l'exemplaire.
                            </p>
                            <!-- Global errors (such as AssertQuota!) -->
                            {% for error in form.vars.errors %}
                                <p class="text-xs text-red-600 mt-1 font-semibold">{{ error.message }}</p>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            {% endif %}

            <!-- Form fields for Media (Embedded) -->
            <div class="space-y-4">
                <h3 class="text-sm font-semibold uppercase tracking-wider text-indigo-600 mb-2 border-b border-indigo-50 pb-1">
                    1. Caractéristiques de l'Édition (Catalogue)
                </h3>
                {{ form_widget(form.media) }}
            </div>

            <!-- Form fields for Copy (Condition, Notes) -->
            <div class="space-y-4 mt-6">
                <h3 class="text-sm font-semibold uppercase tracking-wider text-indigo-600 mb-2 border-b border-indigo-50 pb-1">
                    2. Détails de Votre Exemplaire
                </h3>
                
                <div>
                    {{ form_label(form.condition) }}
                    <div class="mt-1">
                        {{ form_widget(form.condition) }}
                    </div>
                    <p class="text-xs text-red-600 mt-1 font-semibold">{{ form_errors(form.condition) }}</p>
                </div>

                <div>
                    {{ form_label(form.personalNotes) }}
                    <div class="mt-1">
                        {{ form_widget(form.personalNotes) }}
                    </div>
                    <p class="text-xs text-red-600 mt-1">{{ form_errors(form.personalNotes) }}</p>
                </div>
            </div>

            <div class="flex items-center justify-end space-x-3 pt-6 border-t border-gray-100">
                <a href="{{ path('app_dashboard') }}" class="px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                    Annuler
                </a>
                <button type="submit" class="px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                    Ajouter à ma bibliothèque
                </button>
            </div>
        {{ form_end(form) }}
    </div>
</div>

<!-- Vanilla JS API Integration Script -->
<script>
document.addEventListener('DOMContentLoaded', () => {
    const statusText = document.getElementById('api_status');
    
    function showStatus(text, isError = false) {
        if (statusText) {
            statusText.classList.remove('hidden', 'text-gray-500', 'text-green-600', 'text-red-600');
            statusText.classList.add(isError ? 'text-red-600' : 'text-green-600');
            statusText.textContent = text;
        }
    }

    // Conditional Custom Type Visibility Logic
    const selectElement = document.getElementById('custom_media_type_select');
    const customTypeInput = document.querySelector('input[id$="_media_customType"]');
    
    if (selectElement && customTypeInput) {
        const container = customTypeInput.closest('div');
        
        function toggleCustomType() {
            if (selectElement.value === 'Autre') {
                container.style.display = 'block';
            } else {
                container.style.display = 'none';
                customTypeInput.value = ''; // clear input if hidden
            }
        }
        
        // Listen for change events
        selectElement.addEventListener('change', toggleCustomType);
        
        // Trigger initially
        toggleCustomType();
    }

    {% if type == 'book' %}
    {
        // Book Autofill Logic
        const searchBtn = document.getElementById('btn_search_book');
        const isbnInput = document.getElementById('api_search_isbn');

        searchBtn.addEventListener('click', () => {
            const isbn = isbnInput.value.trim();
            if (!isbn) {
                showStatus('Veuillez saisir un ISBN.', true);
                return;
            }

            showStatus('Recherche en cours dans l\'API Google Books...', false);
            statusText.classList.add('text-gray-500');

            fetch(`/api/metadata/book/${isbn}`)
                .then(res => {
                    if (!res.ok) throw new Error();
                    return res.json();
                })
                .then(data => {
                    // Populate Symfony Form Fields
                    document.querySelector('input[id$="_media_title"]').value = data.title;
                    document.querySelector('input[id$="_media_author"]').value = data.author;
                    document.querySelector('input[id$="_media_isbn"]').value = data.isbn;

                    showStatus('✨ Formulaire pré-rempli avec succès : "' + data.title + '" !');
                })
                .catch(() => {
                    showStatus('❌ Aucun livre trouvé pour cet ISBN. Saisie manuelle nécessaire.', true);
                });
        });
    }
    {% else %}
    {
        // Movie Autofill Logic
        const searchBtn = document.getElementById('btn_search_movie');
        const titleInput = document.getElementById('api_search_title');
        const suggestionsBox = document.getElementById('movie_suggestions');

        searchBtn.addEventListener('click', () => {
            const query = titleInput.value.trim();
            if (!query) {
                showStatus('Veuillez saisir un titre.', true);
                return;
            }

            showStatus('Recherche en cours dans l\'API TMDb...', false);
            statusText.classList.add('text-gray-500');

            fetch(`/api/metadata/movie/search?q=${encodeURIComponent(query)}`)
                .then(res => {
                    if (!res.ok) throw new Error();
                    return res.json();
                })
                .then(results => {
                    suggestionsBox.innerHTML = '';
                    if (results.length === 0) {
                        showStatus('❌ Aucun film trouvé. Saisie manuelle nécessaire.', true);
                        suggestionsBox.classList.add('hidden');
                        return;
                    }

                    results.slice(0, 5).forEach(movie => {
                        const year = movie.release_date ? movie.release_date.substring(0, 4) : 'année inconnue';
                        const div = document.createElement('div');
                        div.className = 'px-4 py-2 hover:bg-gray-100 cursor-pointer text-sm font-medium text-gray-800 border-b border-gray-100 last:border-0';
                        div.textContent = `🎬 ${movie.title} (${year})`;
                        div.addEventListener('click', () => selectMovie(movie.id));
                        suggestionsBox.appendChild(div);
                    });

                    suggestionsBox.classList.remove('hidden');
                    statusText.classList.add('hidden');
                })
                .catch(() => {
                    showStatus('❌ Erreur de communication avec l\'API de recherche.', true);
                });
        });

        function selectMovie(id) {
            suggestionsBox.classList.add('hidden');
            showStatus('Récupération des détails complets du film...', false);
            statusText.classList.add('text-gray-500');

            fetch(`/api/metadata/movie/details/${id}`)
                .then(res => {
                    if (!res.ok) throw new Error();
                    return res.json();
                })
                .then(movie => {
                    // Populate Symfony Form Fields
                    document.querySelector('input[id$="_media_title"]').value = movie.title;
                    document.querySelector('input[id$="_media_director"]').value = movie.director || '';
                    document.querySelector('input[id$="_media_releaseYear"]').value = movie.releaseYear || '';
                    document.querySelector('input[id$="_media_durationInMinutes"]').value = movie.durationInMinutes || '';

                    showStatus('✨ Formulaire pré-rempli avec succès : "' + movie.title + '" !');
                })
                .catch(() => {
                    showStatus('❌ Erreur lors de la récupération des détails.', true);
                });
        }

        // Close suggestions on outside click
        document.addEventListener('click', (e) => {
            if (!suggestionsBox.contains(e.target) && e.target !== titleInput && e.target !== searchBtn) {
                suggestionsBox.classList.add('hidden');
            }
        });
    }
    {% endif %}
});
</script>
{% endblock %}
