{% extends 'base.html.twig' %}

{% block title %}Mes Prêts en Cours - Koffrete{% endblock %}

{% block body %}
<nav class="bg-indigo-600 shadow-md">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
            <div class="flex items-center">
                <a href="{{ path('app_dashboard') }}" class="text-white text-xl font-bold hover:opacity-90 transition">Koffrete 🗃️</a>
                <span class="text-indigo-200 text-sm ml-4 font-medium hidden sm:block">Suivi des Prêts</span>
            </div>
            <div class="flex items-center space-x-4">
                <a href="{{ path('app_dashboard') }}" class="text-indigo-100 hover:text-white text-sm font-medium">
                    ← Retour au tableau de bord
                </a>
            </div>
        </div>
    </div>
</nav>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="text-center max-w-3xl mx-auto space-y-4 mb-12">
        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-indigo-100 text-indigo-800">
            🤝 Gestionnaire de Prêts Personnel
        </span>
        <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-950">
            Vos Prêts Actifs
        </h1>
        <p class="text-lg text-gray-600">
            Consultez tous les ouvrages et médias que vous avez prêtés à vos proches et enregistrez facilement leur retour physique.
        </p>
    </div>

    {% if activeLoans is empty %}
        <div class="text-center bg-white rounded-lg shadow py-12 px-4 border border-dashed border-gray-300 max-w-xl mx-auto">
            <span class="text-4xl">🤝</span>
            <h4 class="mt-4 text-lg font-medium text-gray-900">Aucun prêt en cours</h4>
            <p class="mt-1 text-sm text-gray-500">Tous vos médias sont bien rangés dans votre bibliothèque personnelle !</p>
            <div class="mt-6">
                <a href="{{ path('app_dashboard') }}" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700">
                    Consulter ma bibliothèque
                </a>
            </div>
        </div>
    {% else %}
        <div class="bg-white shadow overflow-hidden sm:rounded-md border border-gray-150">
            <ul class="divide-y divide-gray-200">
                {% for active in activeLoans %}
                    {% set loan = active.loan %}
                    {% set item = active.item %}
                    <li>
                        <div class="px-4 py-5 sm:px-6 flex items-center justify-between hover:bg-gray-50 transition">
                            <div class="flex items-center space-x-4">
                                <div class="flex-shrink-0 text-3xl">
                                    {% if item.media.author is defined %}
                                        📖
                                    {% elseif item.media.director is defined %}
                                        🎬
                                    {% else %}
                                        📦
                                    {% endif %}
                                </div>
                                <div>
                                    <h3 class="text-lg font-bold text-gray-900 leading-6">{{ item.media.title }}</h3>
                                    <p class="text-sm text-gray-500">
                                        Prêté à <span class="font-bold text-indigo-600">{{ loan.borrower }}</span>
                                    </p>
                                    <div class="flex flex-wrap gap-x-4 gap-y-1 mt-2 text-xs text-gray-400 font-medium">
                                        <span>Prêté le : {{ loan.lentAt|date('d/m/Y') }}</span>
                                        {% if loan.expectedReturnAt %}
                                            <span>•</span>
                                            <span>Retour attendu le : {{ loan.expectedReturnAt|date('d/m/Y') }}</span>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                            <div class="flex items-center space-x-4">
                                {% if active.isOverdue %}
                                    <span class="px-2.5 py-1 rounded-full text-xs font-bold bg-red-100 text-red-800 border border-red-200 animate-pulse">
                                        ⚠️ En retard !
                                    </span>
                                {% else %}
                                    <span class="px-2.5 py-1 rounded-full text-xs font-semibold bg-green-50 text-green-800 border border-green-200">
                                        ✓ En cours
                                    </span>
                                {% endif %}

                                <a href="{{ path('app_dashboard_return', {'id': item.id}) }}" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 transition">
                                    Enregistrer le retour
                                </a>
                            </div>
                        </div>
                    </li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}
</div>
{% endblock %}
