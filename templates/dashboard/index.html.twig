{% extends 'base.html.twig' %}

{% block title %}Mon Tableau de Bord - Koffrete{% endblock %}

{% block body %}
<nav class="bg-indigo-600 shadow-md">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
            <div class="flex items-center">
                <a href="{{ path('app_dashboard') }}" class="text-white text-xl font-bold hover:opacity-90 transition">Koffrete 🗃️</a>
                <span class="text-indigo-200 text-sm ml-4 font-medium hidden sm:block">Gestion de Collection Multi-catégories</span>
            </div>
            <div class="flex items-center space-x-4">
                <a href="{{ path('app_dashboard_loans') }}" class="text-indigo-100 hover:text-white text-sm font-medium">
                    🤝 Mes Prêts
                </a>
                <a href="{{ path('app_dashboard_subscription') }}" class="text-indigo-100 hover:text-white text-sm font-medium">
                    💳 Mon Abonnement
                </a>
                <span class="text-white text-sm bg-indigo-700 px-3 py-1.5 rounded-md font-medium">
                    👤 {{ app.user.userIdentifier }}
                </span>
                <a href="{{ path('app_logout') }}" class="text-indigo-100 hover:text-white text-sm font-medium">
                    Déconnexion
                </a>
            </div>
        </div>
    </div>
</nav>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Flash Messages -->
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="mb-6 p-4 rounded-lg shadow-sm border {% if label == 'success' %}bg-green-50 border-green-200 text-green-800{% else %}bg-red-50 border-red-200 text-red-800{% endif %} flex items-center justify-between">
                <div class="flex items-center space-x-2">
                    <span>{% if label == 'success' %}✅{% else %}❌{% endif %}</span>
                    <p class="text-sm font-medium">{{ message }}</p>
                </div>
            </div>
        {% endfor %}
    {% endfor %}

    <!-- Quota & Subscription Banner -->
    <div class="bg-white rounded-lg shadow p-6 mb-8 border border-gray-100">
        <div class="md:flex md:items-center md:justify-between">
            <div class="flex-1 min-w-0">
                <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:text-3xl sm:truncate">
                    Votre Espace Collectionneur
                </h2>
                <div class="mt-1 flex flex-col sm:flex-row sm:flex-wrap sm:space-x-6">
                    <div class="mt-2 flex items-center text-sm text-gray-500">
                        <a href="{{ path('app_dashboard_subscription') }}" class="px-2.5 py-1 rounded-full text-xs font-semibold bg-indigo-100 text-indigo-800 hover:bg-indigo-200 transition">
                            Plan : {{ quota.subscriptionName }} ⚙️
                        </a>
                    </div>
                </div>
            </div>
            <div class="mt-5 md:mt-0 md:ml-4 flex-shrink-0 w-full md:w-64">
                <div class="text-sm font-medium text-gray-500 mb-1 flex justify-between">
                    <span>Quota de médias :</span>
                    <span class="font-bold text-gray-900">
                        {{ quota.current }} / {% if quota.limit is null %}∞{% else %}{{ quota.limit }}{% endif %}
                    </span>
                </div>
                {% if quota.limit is not null %}
                    <div class="w-full bg-gray-200 rounded-full h-2.5">
                        <div class="h-2.5 rounded-full {% if quota.percentage >= 90 %}bg-red-600{% elseif quota.percentage >= 70 %}bg-yellow-400{% else %}bg-green-500{% endif %}" style="width: {{ quota.percentage }}%"></div>
                    </div>
                    {% if quota.isFull %}
                        <p class="text-xs text-red-600 font-semibold mt-2">
                            ⚠️ Votre quota est plein. Prenez un abonnement pour ajouter plus de médias !
                        </p>
                    {% else %}
                        <p class="text-xs text-gray-500 mt-1.5">
                            Il vous reste {{ quota.limit - quota.current }} emplacements libres.
                        </p>
                    {% endif %}
                {% else %}
                    <div class="w-full bg-yellow-100 border border-yellow-300 rounded-lg p-2 flex items-center">
                        <span class="text-yellow-800 text-xs font-semibold">✨ Accès Premium Illimité Activé</span>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    <!-- Universal Search Bar -->
    <div class="bg-white rounded-lg shadow p-4 mb-6 border border-gray-100">
        <div class="relative rounded-md shadow-sm">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <span class="text-gray-400 text-lg">🔍</span>
            </div>
            <input type="text" id="universal_search" placeholder="Rechercher par titre, auteur, réalisateur, acteur principal, année, état, lieu de stockage (ex: Caisse 3)..." class="focus:ring-indigo-500 focus:border-indigo-500 block w-full pl-10 pr-3 py-3 border-gray-300 rounded-md text-sm text-gray-900 placeholder-gray-400 bg-gray-50">
        </div>
    </div>

    <!-- Collection Section -->
    <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center mb-6 space-y-4 sm:space-y-0">
        <h3 class="text-xl font-bold text-gray-900">Ma Bibliothèque (<span id="visible_count">{{ items|length }}</span>/{{ items|length }} exemplaires)</h3>
        <div class="flex flex-wrap gap-2">
            <a href="{{ path('app_dashboard_add_book') }}" class="inline-flex items-center px-3 py-2 border border-transparent text-xs sm:text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700">
                📖 Livre
            </a>
            <a href="{{ path('app_dashboard_add_dvd') }}" class="inline-flex items-center px-3 py-2 border border-transparent text-xs sm:text-sm font-medium rounded-md shadow-sm text-white bg-red-600 hover:bg-red-700">
                🎬 DVD / Film
            </a>
            <a href="{{ path('app_dashboard_add_custom') }}" class="inline-flex items-center px-3 py-2 border border-transparent text-xs sm:text-sm font-medium rounded-md shadow-sm text-white bg-purple-600 hover:bg-purple-700">
                ➕ Autre Collection (CD, Vinyle, Bolide, Pièce...)
            </a>
        </div>
    </div>

    {% if items is empty %}
        <div class="text-center bg-white rounded-lg shadow py-12 px-4 border border-dashed border-gray-300">
            <span class="text-4xl">📚</span>
            <h4 class="mt-4 text-lg font-medium text-gray-900">Votre collection est vide</h4>
            <p class="mt-1 text-sm text-gray-500">Commencez à inventorier vos livres, bolides, flippers, pièces et médias dès maintenant.</p>
            <div class="mt-6 flex flex-wrap justify-center gap-3">
                <a href="{{ path('app_dashboard_add_book') }}" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700">
                    📖 Ajouter un Livre
                </a>
                <a href="{{ path('app_dashboard_add_dvd') }}" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-red-600 hover:bg-red-700">
                    🎬 Ajouter un DVD
                </a>
                <a href="{{ path('app_dashboard_add_custom') }}" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-purple-600 hover:bg-purple-700">
                    ➕ Autre Collection (Bolide, Flipper, Pièce...)
                </a>
            </div>
        </div>
    {% else %}
        <div id="no_results" class="text-center bg-white rounded-lg shadow py-12 px-4 border border-dashed border-gray-200 hidden">
            <span class="text-4xl">🧐</span>
            <h4 class="mt-4 text-lg font-medium text-gray-900">Aucun résultat trouvé</h4>
            <p class="mt-1 text-sm text-gray-500">Essayez de modifier votre mot-clé de recherche.</p>
        </div>

        <div id="collection_grid" class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {% for item in items %}
                {% set actors_search = item.media.actors is defined and item.media.actors ? item.media.actors|join(' ') : '' %}
                {% set author_search = item.media.author is defined ? item.media.author : '' %}
                {% set director_search = item.media.director is defined ? item.media.director : '' %}
                {% set year_search = item.media.releaseYear is defined ? item.media.releaseYear : '' %}
                {% set custom_type_search = item.media.type is defined ? item.media.type : '' %}
                {% set custom_desc_search = (item.media.type is defined and item.media.attributes and item.media.attributes.description is defined) ? item.media.attributes.description : '' %}
                
                {% set active_loan = null %}
                {% for loan in item.loans %}
                    {% if loan.returnedAt is null %}
                        {% set active_loan = loan %}
                    {% endif %}
                {% endfor %}
                
                <!-- Compiled lowercase metadata string for client-side search -->
                <div class="media-card bg-white overflow-hidden shadow rounded-lg border border-gray-150 flex flex-col justify-between"
                     data-search="{{ (item.media.title ~ ' ' ~ author_search ~ ' ' ~ director_search ~ ' ' ~ actors_search ~ ' ' ~ year_search ~ ' ' ~ custom_type_search ~ ' ' ~ custom_desc_search ~ ' ' ~ item.condition ~ ' ' ~ item.personalNotes ~ (active_loan ? ' prêté lent ' ~ active_loan.borrower : ''))|lower }}">
                    
                    {% if item.imagePath %}
                        <div class="h-48 w-full overflow-hidden bg-gray-100 flex items-center justify-center border-b border-gray-100">
                            <img src="{{ asset(item.imagePath) }}" alt="{{ item.media.title }}" class="object-cover w-full h-full">
                        </div>
                    {% endif %}

                    <div class="p-5">
                        <div class="flex items-start justify-between">
                            <div class="flex-1">
                                <div class="flex items-center space-x-2">
                                    {% if item.media.author is defined %}
                                        <span class="text-2xl" title="Livre">📖</span>
                                        <span class="text-xs font-semibold uppercase text-blue-600 tracking-wider">Livre</span>
                                    {% elseif item.media.director is defined %}
                                        <span class="text-2xl" title="DVD">🎬</span>
                                        <span class="text-xs font-semibold uppercase text-red-600 tracking-wider">DVD / Film</span>
                                    {% else %}
                                        {% set category_emoji = '📦' %}
                                        {% if item.media.type == 'Voiture' %}{% set category_emoji = '🚗' %}
                                        {% elseif item.media.type == 'Moto' %}{% set category_emoji = '🏍️' %}
                                        {% elseif item.media.type == 'Pièce détachée' %}{% set category_emoji = '⚙️' %}
                                        {% elseif item.media.type == 'Flipper' %}{% set category_emoji = '👾' %}
                                        {% elseif item.media.type == 'Juke-box' %}{% set category_emoji = '📻' %}
                                        {% elseif item.media.type == 'Vinyle' %}{% set category_emoji = '💿' %}
                                        {% endif %}
                                        <span class="text-2xl" title="{{ item.media.type }}">{{ category_emoji }}</span>
                                        <span class="text-xs font-semibold uppercase text-purple-600 tracking-wider">{{ item.media.type }}</span>
                                    {% endif %}

                                    {% if active_loan %}
                                        <span class="px-2 py-0.5 rounded-full text-[10px] font-bold bg-amber-100 text-amber-800 border border-amber-200">
                                            🤝 Prêt : {{ active_loan.borrower }}
                                        </span>
                                    {% endif %}
                                </div>
                                <h4 class="text-lg font-bold text-gray-900 mt-2">{{ item.media.title }}</h4>
                                
                                {% if item.media.author is defined %}
                                    <p class="text-sm text-gray-600 font-medium">Auteur : <span class="highlight-target">{{ item.media.author }}</span></p>
                                    {% if item.media.isbn %}
                                        <p class="text-xs text-gray-400 font-mono mt-0.5">ISBN : {{ item.media.isbn }}</p>
                                    {% endif %}
                                {% elseif item.media.director is defined %}
                                    <p class="text-sm text-gray-600 font-medium">Réalisateur : <span class="highlight-target">{{ item.media.director ?: 'Inconnu' }}</span></p>
                                    <div class="flex space-x-2 text-xs text-gray-400 font-medium mt-0.5">
                                        <span>Année : {{ item.media.releaseYear ?: 'Inconnue' }}</span>
                                        <span>•</span>
                                        <span>Durée : {{ item.media.durationInMinutes ?: '?' }} min</span>
                                    </div>
                                    {% if item.media.actors %}
                                        <p class="text-xs text-gray-500 mt-2 italic line-clamp-1">
                                            Acteurs : <span class="highlight-target">{{ item.media.actors|join(', ') }}</span>
                                        </p>
                                    {% endif %}
                                {% else %}
                                    <!-- Custom / Other categories -->
                                    {% if item.media.attributes and item.media.attributes.description is defined and item.media.attributes.description %}
                                        <p class="text-xs text-gray-600 mt-2 font-medium bg-gray-50 p-2.5 rounded border border-gray-150 whitespace-pre-line">{{ item.media.attributes.description }}</p>
                                    {% endif %}
                                {% endif %}
                            </div>
                        </div>

                        <!-- Personal copy attributes -->
                        <div class="border-t border-gray-100 mt-4 pt-4 space-y-2">
                            <div class="flex items-center justify-between text-xs">
                                <span class="text-gray-500 font-medium">État :</span>
                                <span class="px-2 py-0.5 rounded-full font-semibold bg-green-50 text-green-800 border border-green-200">
                                    {{ item.condition }}
                                </span>
                            </div>
                            {% if item.personalNotes %}
                                <div class="text-xs text-gray-600 bg-gray-50 p-2 rounded border border-gray-100">
                                    <span class="font-semibold text-gray-500">Note :</span> {{ item.personalNotes }}
                                </div>
                            {% endif %}
                        </div>
                    </div>
                    
                    <!-- Action Buttons footer of card -->
                    <div class="bg-gray-50 px-5 py-3 border-t border-gray-100 flex items-center justify-between text-xs gap-4">
                        <span class="text-gray-400">Acquis le {{ item.acquiredAt|date('d/m/Y') }}</span>
                        <div class="flex items-center space-x-3">
                            <a href="{{ path('app_dashboard_edit', {'id': item.id}) }}" class="text-indigo-600 hover:text-indigo-900 font-semibold transition">
                                Modifier
                            </a>
                            <span class="text-gray-200">|</span>
                            
                            {% if active_loan %}
                                <a href="{{ path('app_dashboard_return', {'id': item.id}) }}" class="text-green-600 hover:text-green-900 font-semibold transition" title="Enregistrer le retour du prêt">
                                    Retourner
                                </a>
                            {% else %}
                                <a href="{{ path('app_dashboard_lend', {'id': item.id}) }}" class="text-amber-600 hover:text-amber-900 font-semibold transition">
                                    Prêter
                                </a>
                            {% endif %}
                            <span class="text-gray-200">|</span>

                            <a href="{{ path('app_dashboard_delete', {'id': item.id}) }}" onclick="return confirm('Êtes-vous sûr de vouloir retirer cet exemplaire de votre collection ? (Cette action est irréversible)');" class="text-red-500 hover:text-red-700 font-semibold transition" title="Supprimer de la collection">
                                🗑️ Retirer
                            </a>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>

<!-- Instant Universal Search Javascript -->
<script>
document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('universal_search');
    
    if (searchInput) {
        const cards = document.querySelectorAll('.media-card');
        const noResults = document.getElementById('no_results');
        const visibleCountSpan = document.getElementById('visible_count');

        searchInput.addEventListener('input', () => {
            const query = searchInput.value.trim().toLowerCase();
            let visibleCount = 0;

            cards.forEach(card => {
                const searchString = card.getAttribute('data-search') || '';
                
                if (searchString.includes(query)) {
                    card.classList.remove('hidden');
                    visibleCount++;
                } else {
                    card.classList.add('hidden');
                }
            });

            // Update visible counter
            if (visibleCountSpan) {
                visibleCountSpan.textContent = visibleCount;
            }

            // Display or hide no results placeholder
            if (noResults) {
                if (visibleCount === 0 && cards.length > 0) {
                    noResults.classList.remove('hidden');
                } else {
                    noResults.classList.add('hidden');
                }
            }
        });
    }
});
</script>
{% endblock %}
